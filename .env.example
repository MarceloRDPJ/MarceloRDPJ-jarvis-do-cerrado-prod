# ================================
# JARVIS DO CERRADO - CONFIGURAÇÃO (.env)
# ================================
# Este arquivo contém todas as variáveis de ambiente necessárias para rodar o Jarvis.
# Copie este arquivo para .env e preencha com seus dados reais.
# Exemplo: cp .env.example .env

# ================================
# TELEGRAM BOT (OBRIGATÓRIO)
# ================================
# Token do bot obtido com o @BotFather
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Seu ID numérico do Telegram (para segurança e validação)
# Apenas este ID poderá controlar o bot.
# Obtenha enviando /start para @userinfobot ou similar.
ALLOWED_USER_ID=123456789

# ================================
# IA LOCAL GRATUITA (LLAMA.CPP)
# ================================
# Raspberry Pi 3B: prefira llama-cli com modelo GGUF pequeno.
# Preferencial: llama-server local com modelo carregado.
# Para desativar completamente o LLM local, use: LOCAL_LLM_BACKEND=disabled
LOCAL_LLM_ENABLED=true
LOCAL_LLM_COMMAND=llama-cli
LOCAL_LLM_BACKEND=server
LOCAL_LLM_SERVER_URL=http://127.0.0.1:8081
LOCAL_LLM_URL=http://127.0.0.1:8081/completion
LOCAL_LLM_CLI_PATH=/opt/bot/llama.cpp/build/bin/llama-cli
LOCAL_LLM_MODEL_PATH=/opt/bot/models/SmolLM2-135M-Instruct-Q4_K_M.gguf

# Mais seguro para Raspberry Pi 3B: SmolLM2-135M. Melhor PT, mas mais pesado: gemma-3-270m-it.
LOCAL_LLM_MODEL=SmolLM2-135M-Instruct
LOCAL_LLM_THREADS=1
LOCAL_LLM_CONTEXT_SIZE=384
LOCAL_LLM_TIMEOUT_SECONDS=12
LOCAL_LLM_MAX_TOKENS=48
LOCAL_LLM_TEMPERATURE=0.2

# ================================
# FERRAMENTAS LOCAIS DE INTERNET (GRATUITAS)
# ================================
# Não usa OpenAI/DeepSeek, Brave, Tavily, Serper nem browser headless.
# Usa requests, RSS, páginas públicas leves e APIs públicas gratuitas quando disponíveis.
LOCAL_WEB_TOOLS_ENABLED=true
WEB_FETCH_TIMEOUT_SECONDS=10
WEB_FETCH_MAX_CHARS=12000
WEB_USER_AGENT=JarvisDoCerrado/1.0

# Feeds RSS opcionais, separados por vírgula. Se vazio, notícias avisam que não há fonte configurada.
RSS_FEEDS_ENABLED=true
RSS_FEEDS=

# URL opcional de uma fonte leve/textual para tabela do Brasileirão.
# Se vazio, o bot avisa que não há fonte configurada para tabela.
CURRENT_INFO_BRASILEIRAO_URL=

# ================================
# WAKE-ON-LAN (WOL) CONFIGURATION
# ================================
# MAC address do PC que será ligado remotamente.
# OBRIGATÓRIO para a função 'Ligar PC' funcionar.
# Formato: AA:BB:CC:DD:EE:FF ou AA-BB-CC-DD-EE-FF
# Obtenha com: ip link show (Linux) ou ipconfig /all (Windows)
PC_MAC=AA:BB:CC:DD:EE:FF

# IP do PC (opcional, usado apenas para verificar se o PC está online/pingando)
# Se não definido, usa padrão 192.168.0.100
PC_IP=192.168.0.100

# ================================
# TIMEZONE & REGIONAL
# ================================
# Fuso horário para agendamentos e logs
TIMEZONE=America/Sao_Paulo

# ================================
# TUNING / AJUSTES FINOS (OPCIONAL)
# ================================
# Nível de confiança mínimo para entender um comando (0.0 a 1.0)
INTENT_CONFIDENCE_THRESHOLD=0.88

# Intervalo do loop de agendamento em segundos
SCHEDULER_INTERVAL_SECONDS=30

# Intervalo mínimo entre lembretes de água (minutos)
HYDRATION_MIN_INTERVAL_MINUTES=10
